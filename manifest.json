{
  "manifest_version": 3,
  "name": "Claude Chat Exporter",
  "version": "0.4.0",
  "description": "Export a Claude.ai conversation to a nicely-formatted .txt file.",
  "author": "vanawaker",
  "homepage_url": "https://github.com/vanawaker/claude-chat-exporter",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/chat/*",
        "https://claude.ai/chats/*",
        "https://claude.ai/project/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "claude-chat-exporter@vanawaker",
      "strict_min_version": "115.0"
    }
  }
}
